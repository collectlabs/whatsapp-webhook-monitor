# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Webhook (verificação pela Meta)
WEBHOOK_VERIFY_TOKEN=your_verify_token

# API (send-template, phone-numbers)
API_KEY=your_api_key

# WhatsApp Cloud API - BMs e WABAs
# A estrutura (BMs, WABAs, phone_ids) fica nas tabelas bms e wabas no Supabase.
# No .env: apenas um token por BM. O nome deve ser igual ao campo "name" da tabela bms.
# Exemplo: se existe uma BM com name = "VIVENTI" no Supabase, defina:
WHATSAPP_ACCESS_TOKEN_VIVENTI=EAA_...

# Outra BM (name = "OUTRA_OPERACAO" na tabela bms):
# WHATSAPP_ACCESS_TOKEN_OUTRA_OPERACAO=EAA_...

# OpenAI (respostas automáticas com IA - opcional)
OPENAI_API_KEY=sk-your-key
AI_ENABLED=true
AI_MODEL=gpt-4o-mini
